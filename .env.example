DATABASE_URL=
GOOGLE_SERVICE_ACCOUNT_KEY=
RESEND_API_KEY=

# NextAuth (Auth.js v5)
# 生成コマンド: openssl rand -base64 32
NEXTAUTH_SECRET=
# 本番の場合: https://your-domain.example.com
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → 認証情報 → OAuth 2.0 クライアントID を発行)
# 承認済みリダイレクトURI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 管理画面にログイン可能なメールアドレス（カンマ区切り）
# 例: restaurant.ai.lab@gmail.com,another@example.com
ADMIN_ALLOWED_EMAILS=restaurant.ai.lab@gmail.com

# Vercel Blob（コース画像アップロード用）
# Vercel ダッシュボードの Storage タブで Blob を作成して取得
BLOB_READ_WRITE_TOKEN=
